<?xml version="1.0"?>
<robot name="puzzlebot" xmlns:xacro="http://www.ros.org/wiki/xacro">

 <xacro:include filename="$(find puzzlebot_description)/urdf/parameters.xacro"/>
  <xacro:include filename="$(find puzzlebot_description)/urdf/materials.xacro"/>
  <xacro:include filename="$(find puzzlebot_description)/urdf/macros.xacro"/>

  <!-- Arguments for using multiple robots if necessary -->
  <xacro:arg name="prefix" default=""/>
  <xacro:property name="prefix" value="$(arg prefix)"/>



  <!--
    base_footprint:reference frame fo assuming the robot is at z=0 (floor) -->
  <link name="${prefix}base_footprint"/>

  <joint name="${prefix}base_footprint_to_base_link" type="fixed">
    <parent link="${prefix}base_footprint"/>
    <child  link="${prefix}base_link"/>
    <!-- the chassis lays on the floor considering wheels radius-->
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>


  <link name="${prefix}base_link"/>

  <joint name="${prefix}base_link_to_chassis" type="fixed">
    <parent link="${prefix}base_link"/>
    <child  link="${prefix}chassis"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>


  <link name="${prefix}chassis">

    <visual>
      <origin xyz="0.050 0 0.1" rpy="${PI/2} 0 ${PI}"/>
      <geometry>
        <mesh filename="file://${mesh_chassis}"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${chassis_mass}"/>
      <xacro:box_inertia
        m="${chassis_mass}"
        x="${chassis_length}"
        y="${chassis_width}"
        z="${chassis_height}"/>
    </inertial>

  </link>



  <link name="${prefix}caster_wheel">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://${caster_wheel}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${caster_mass}"/>
      <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}"/>
    </inertial>

  </link>

  <joint name="${prefix}chassis_to_caster" type="fixed">
    <parent link="${prefix}chassis"/>
    <child  link="${prefix}caster_wheel"/>
    <origin xyz="${caster_x} ${caster_y} ${caster_z}" rpy="0 0 0"/>
  </joint>



  <!-- RIGHT WHEEL -->
  <link name="${prefix}right_wheel">

    <visual>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <mesh filename="file://${mesh_wheel}"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder length="${wheel_thickness}" radius="${wheel_radius}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${wheel_mass}"/>
      <!--
        El cilindro tiene su eje en Z antes de la rotación visual.
        La macro cylinder_inertia asume eje Z como eje de simetría.
        Cuando el joint rota la rueda para que gire en Y, las inercias
        se transforman automáticamente — no hay que hacer nada extra.
      -->
      <xacro:cylinder_inertia
        m="${wheel_mass}"
        r="${wheel_radius}"
        l="${wheel_thickness}"/>
    </inertial>

  </link>

  <joint name="${prefix}base_to_right_wheel" type="continuous">
    <parent link="${prefix}chassis"/>
    <child  link="${prefix}right_wheel"/>
    <origin xyz="${wheel_x_offset} -${wheel_separation} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <!-- Left wheel -->
  <link name="${prefix}left_wheel">

    <visual>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <mesh filename="file://${mesh_wheel}"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder length="${wheel_thickness}" radius="${wheel_radius}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${wheel_mass}"/>
      <xacro:cylinder_inertia
        m="${wheel_mass}"
        r="${wheel_radius}"
        l="${wheel_thickness}"/>
    </inertial>

  </link>

  <joint name="${prefix}base_to_left_wheel" type="continuous">
    <parent link="${prefix}chassis"/>
    <child  link="${prefix}left_wheel"/>
    <origin xyz="${wheel_x_offset} ${wheel_separation} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>




<!-- camera -->
  <link name="${prefix}camera">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 ${PI}"/>
      <geometry>
        <!-- <mesh filename="file://${mesh_camera}"/> -->
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_length} ${camera_width} ${camera_height}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${camera_mass}"/>
      <!--
        Inercias calculadas con la geometría real de la caja.
      -->
      <xacro:box_inertia
        m="${camera_mass}"
        x="${camera_length}"
        y="${camera_width}"
        z="${camera_height}"/>
    </inertial>

  </link>

  <joint name="${prefix}chassis_to_camera" type="fixed">
    <parent link="${prefix}chassis"/>
    <child  link="${prefix}camera"/>
    <origin xyz="${camera_x} ${camera_y} ${camera_z}"
            rpy="${PI/2} ${PI} ${PI/2}"/>
  </joint>



  <!-- lidar -->
  <link name="${prefix}lidar">

    <visual>
      <origin xyz="0.07 -0.013 -0.04" rpy="${PI/2} 0 0"/>
      <geometry>
        <!--<mesh filename="file://${mesh_lidar}"/> -->
      </geometry>
      <material name="dark_grey"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.05"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${lidar_mass}"/>
      <xacro:cylinder_inertia
        m="${lidar_mass}"
        r="0.05"
        l="0.04"/>
    </inertial>

  </link>

  <joint name="${prefix}chassis_to_lidar" type="fixed">
    <parent link="${prefix}chassis"/>
    <child  link="${prefix}lidar"/>
    <origin xyz="${lidar_x} ${lidar_y} ${lidar_z}" rpy="0 0 ${PI}"/>
  </joint>

</robot>
