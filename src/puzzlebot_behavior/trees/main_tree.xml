<root BTCPP_format="4">
 <BehaviorTree ID = "PuzzlebotTree">
  <Repeat num_cycles = "-1">

   <Fallback name = "TryPickPlace"> <!--Normal task start picking-->
     <Sequence name = "SequencePickPlace"> <!--Starts normal sequence for picking-->

      <GetTargetPose
        pallet_pose = "{target_pose}"/> <!--execute the pipeline-->
      <GoToTarget
        target_pose = "{target_pose}"/>

     </Sequence> <!--if could not get target pose, fallback to get closer-->
      <Sequence name = "GetCloser">
        <GoToTarget
            target_pose = "{dummy_pose}"/> <!--This should be a dummy pose to see if now detecting smthg-->

     </Sequence>
   </Fallback>
   </Repeat>
 </BehaviorTree>
 </root>
